DashKey: Press {0} while facing a direction
DodgeInfo:
	'''
	{$Common.DodgeProvided}
	{$Common.DodgeInformation}
	'''

AddedTooltip: {
	/*
	Accessories
	*/
	TitanGloveLine: 10% increased true melee damage
	YoyoGlove: Secondary yoyos will do 50% less damage
	// Also used by Sniper Scope
	EyeoftheGolem: 15% increased critical strike damage
	RifleScope: The scope effect can be toggled with visibility
	ReconScope2: 5% increased ranged critical strike chance
	ArcaneFlower: 5% increased magic damage
	HellfireTreads:
		'''
		50% increased Heat debuff damage, does not stack with downgrades
		All attacks inflict Hellfire
		'''
	FairyBoots:
		'''
		Fairies can spawn at any time on the surface and spawn far more frequently
		Nearby fairies grant +1 HP/s life regen, 4 defense and 10% movement speed
		Fairies are immune to damage and will no longer flee
		'''
	FleshKnucklesLine: Max life increased by 25
	HandWarmer: Provides a regeneration boost while wearing the Snow armor
	/*
	Others
	*/
	TruffleWorm:
		'''
		Summons Duke Fishron if used as bait in the Ocean
		Enrages outside the Ocean
		'''
	SlimeGun: Slimed enemies take more damage from fire-based debuffs
	RodofDiscord: Teleportation is disabled while Chaos State is active
	Pwnhammer:
		'''
		Demon Altars now drop Souls of Night instead of generating ores when destroyed
		Hardmode ores now generate after defeating Mechanical Bosses for the first time
		'''
	// Life Drain
	SoulDrain:
		'''
		This grants +1.5 HP/s life regen and accelerates natural life regen
		Life drain stacks based on the number of enemies being hit
		'''
	GoldenFishingRod: Its fishing line will never break
	Tombstones:
		'''
		13 of any tombstone turns the surrounding area into a graveyard
		Graveyards have various new item sales and recipes
		'''
	FeatherfallPotion: Disables all airborne flight recovery
	CrimsonArmorPieces: +0.5 HP/s life regen
	Picksaw: Can mine Scoria Ore located in the Abyss
}

