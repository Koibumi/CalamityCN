}

EditedTooltip: {
	/*
	Boss Summons
	*/
	Abeemination:
		'''
		Summons the Queen Bee when used in the Jungle
		Enrages outside the Underground Jungle
		'''
	BloodySpine:
		'''
		Summons the Brain of Cthulhu when used in the Crimson
		Despawns outside the Crimson
		'''
	ClothierVoodooDoll:
		'''
		While equipped, summons Skeletron when the Clothier is killed during nighttime
		Enrages during the day
		'You are a terrible person'
		'''
	DeerThing: Summons Deerclops when used in the Snow or Ice biome
	GuideVoodooDoll:
		'''
		Summons the Wall of Flesh if thrown into lava in the underworld while the Guide is alive
		'You are a terrible person'
		'''
	LihzahrdPowerCell:
		'''
		Summons the Golem when used at the Lihzahrd Altar
		Enrages outside the Jungle Temple
		'''
	MechanicalEye: Summons The Twins when used during nighttime
	MechanicalSkull:
		'''
		Summons Skeletron Prime when used during nighttime
		Enrages during the day
		'''
	MechanicalWorm: Summons The Destroyer when used during nighttime
	QueenSlimeCrystal: Summons Queen Slime when used in the Hallow
	SuspiciousLookingEye: Summons the Eye of Cthulhu when used during nighttime
	WormFood:
		'''
		Summons the Eater of Worlds when used in the Corruption
		Despawns outside the Corruption
		'''
	/*
	Life Regen
	*/
	Campfires: Life regen is increased by 0.5 HP/s when near a campfire
	HeartLantern: Grants +1 HP/s life regeneration when placed nearby
	BottledHoney:
		'''
		Grants +1 HP/s life regen for a short time
		Grants an additional +1 HP/s life regen while inflicted with a damaging debuff
		'''
	ShinyStone: Grants +2 HP/s life regen and accelerates natural life regen when not moving
	BandofRegeneration: Grants +1 HP/s life regeneration
	CharmofMyths: Grants +1 HP/s life regeneration and reduces the cooldown of healing potions by 25%
	RegenerationPotion: Provides +2 HP/s life regeneration
	HamBat: Defeating enemies temporarily grants +3 HP/s life regen
	// Vital Crystal
	AegisCrystal: Permanently boosts natural life regeneration
	/*
	OOA armors
	*/
	SquireGreatHelm: Increases your max number of sentries by 1 and grants +2 HP/s life regen
	MonkBrows: Increases your max number of sentries by 1 and increases rogue velocity by 20%
	MonkShirt: 20% increased summon and rogue damage
	MonkPants: 15% increased rogue critical strike chance and 20% increased movement speed
	// Valhalla Knight
	SquireAltShirt: 30% increased summon damage and grants +4 HP/s life regen
	// Shinobi Infiltrator
	MonkAltHead: Increases your max number of sentries by 2 and increases summon & rogue damage by 20%
	MonkAltShirt0: 20% increased summon damage and rogue velocity
	MonkAltShirt1: 5% increased rogue critical strike chance
	MonkAltPants: 20% increased summon damage and rogue critical strike chance
	/*
	Accessories
	*/
	SunMoonStones: critical strike chance, life regeneration,
	CelestialStoneShell: Minor increase to damage,
	PowerBerserkerGlove: 12% increased melee speed, does not stack with downgrades
	MechanicalGlove:
		'''
		12% increased melee damage
		12% increased melee speed, does not stack with downgrades
		'''
	FireGauntlet1: Increases melee knockback and melee attacks inflict Hellfire
	FireGauntlet2:
		'''
		14% increased melee damage
		14% increased melee speed, does not stack with downgrades
		'''
	MoltenQuiver: Lights wooden arrows ablaze and all arrows inflict Hellfire
	RifleScope1: Increase view range for guns (<right> to zoom out)
	RifleScope2: The scope effect can be toggled with visibility
	ReconScope1: 15% increased ranged damage
	SniperScope: 12% increased ranged critical strike chance
	Magiluminescence:
		'''
		Increases movement acceleration and deceleration by 1.75x
		Increases movement speed by 1.15x. This bonus applies to running boot accessories
		'''
	FrogLeg: Increases jump speed by {0}% and allows auto-jump
	// Soaring Insignia
	EmpressFlightBooster1: Increases wing flight time by 33%
	EmpressFlightBooster2: Increases movement speed by 7.5%, jump speed by 10%, and acceleration by 1.25x
	GravityGlobe:
		'''
		Provides 32% increased jump speed and increased fall speed
		Provides a gravitational boost jump, which recharges whenever gravity is flipped
		Slightly improves wingless air movement speed
		Press {$Key.UP} to change gravity
		Press {$Key.DOWN} to fall faster
		'''
	FlameWakerBoots:
		'''
		25% increased Heat debuff damage
		All attacks light enemies on fire
		'Never get cold feet again'
		'''
	/*
	Armor
	*/
	MagicHat: 6% increased magic critical strike chance
	Gi: 10% increased movement and jump speed
	SolarFlarePieces: Grants +1 HP/s life regeneration
	/*
	Potions
	*/
	ArcheryPotion: 5% increased arrow damage and 20% increased arrow speed
	AleSake:
		'''
		Increases melee weapon scale by 25%, but decreases melee speed by 10%
		Counts as an alcohol for Alcohol Poisoning
		{$Common.AlcoholWarning}
		'''
	FlaskofCursedFlames: Melee, Whip, and Rogue attacks inflict enemies with cursed flames
	FlaskofFire: Melee, Whip, and Rogue attacks set enemies on fire
	FlaskofGold: Melee, Whip, and Rogue attacks make enemies drop more gold
	FlaskofIchor: Melee, Whip, and Rogue attacks decrease enemies defense
	FlaskofNanites: Melee, Whip, and Rogue attacks confuse enemies
	FlaskofParty: All attacks cause confetti to appear
	FlaskofPoison: Melee, Whip, and Rogue attacks poison enemies
	FlaskofVenom: Melee, Whip, and Rogue attacks inflict Acid Venom on enemies
	/*
	Others
	*/
	// Aerial Bane
	DD2BetsyBow: Shoots a tight spread of 6 splitting arrows
	GoldPickaxe: Can mine Demonite, Crimtane, Meteorite, Sea Prisms, and Sea Prism Crystals
	MasterExclusive: Master or Revengeance
	// Sparkle Slime Balloon
	GelBalloon:
		'''
		Throws a mixture of slime and sparkling crystals
		Slimed enemies take more damage from fire-based debuffs
		'''
	// Ancient Manipulator
	LunarCraftingStation: Used to craft items from Lunar Fragments, Luminite, and Astral Bars
	AnkhShield: Grants immunity to most debuffs, including Mighty Wind
}

