AggressiveVoucher: {
	DisplayName: Aggressive Voucher
	Tooltip:
		'''
		Favorite this item in your inventory to increase the likelihood of obtaining a desirable reforge
		This effect only applies when reforging accessories
		Targeted Reforge: {0}
		Selectable Reforges: {1}
		[c/aaaaaa:Shift-<right> in your inventory to cycle between targeted reforges]
		'''
	SalesPitch:
		'''
		'That goblin over there, he's just scamming you for your money, you know? But don't worry, me and Hoggart have a solution for that!'
		'Just give him this and watch as he hammers your gear like he was struck with divine inspiration! It'll be like a new item!”
		'''
}

